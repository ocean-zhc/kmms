.menu-grid {
  padding: 0;
}

/* ===== Day Card ===== */
.day-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.8);
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.day-card:active {
  transform: scale(0.985);
}

/* ===== Day Header ===== */
.day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, var(--primary-light) 0%, #ffffff 100%);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.day-label {
  display: flex;
  align-items: center;
}

.day-emoji {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.day-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary-dark);
}

.day-date {
  font-size: 24rpx;
  color: var(--text-hint);
  background: rgba(255,255,255,0.7);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ===== Meal Section ===== */
.meals-wrap {
  padding: 20rpx 28rpx 24rpx;
}

.meal-section {
  margin-bottom: 24rpx;
}

.meal-section:last-child {
  margin-bottom: 0;
}

.meal-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.meal-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary);
  flex-shrink: 0;
}

.meal-snack .meal-dot {
  background: var(--orange);
}

.meal-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #8a9a8e;
  letter-spacing: 1rpx;
}

.meal-emoji {
  display: none;
}

/* ===== Dish Pills ===== */
.dish-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dish-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3a2e;
  transition: all 0.2s ease;
}

.dish-pill:active {
  transform: translateX(8rpx);
}

.dish-emoji-badge {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
}

.dish-name {
  flex: 1;
  line-height: 1.4;
}

.dish-color-0 {
  background: linear-gradient(135deg, #eefbdd, #ddf5c8);
  color: #2d3a2e;
}

.dish-color-1 {
  background: linear-gradient(135deg, #fff3db, #ffe8be);
  color: #2d3a2e;
}

.dish-color-2 {
  background: linear-gradient(135deg, #e4f1ff, #d0e6ff);
  color: #2d3a2e;
}

.dish-color-3 {
  background: linear-gradient(135deg, #fde8ef, #fbd5e2);
  color: #2d3a2e;
}

/* ===== Allergen ===== */
.dish-allergen {
  background: linear-gradient(135deg, #fff1f0, #ffccc7) !important;
  border: 2rpx solid #ffa39e;
}

.allergen-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

/* ===== Favorite ===== */
.fav-icon {
  font-size: 24rpx;
  flex-shrink: 0;
  padding: 4rpx;
}

/* ===== Empty ===== */
.day-empty {
  padding: 32rpx 28rpx;
  text-align: center;
}

.day-empty-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ===== Today Card ===== */
.today-card {
  border: 3rpx solid var(--primary);
  box-shadow: 0 8rpx 32rpx rgba(82, 196, 26, 0.2), 0 0 0 6rpx rgba(82, 196, 26, 0.06);
}

.today-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  background: linear-gradient(135deg, #FFB74D, #FF8A65);
}

.today-banner-icon {
  font-size: 28rpx;
}

.today-banner-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
}

/* ===== Compact Mode ===== */
.compact .day-card {
  margin-bottom: 16rpx;
}

.compact .day-header {
  padding: 16rpx 24rpx;
}

.compact .meals-wrap {
  padding: 12rpx 24rpx 16rpx;
}

.compact .dish-tag {
  font-size: 24rpx;
  padding: 4rpx 14rpx;
}
