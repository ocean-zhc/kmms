.menu-grid {
  padding: 0;
}

/* ===== Day Card ===== */
.day-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.8);
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.day-card:active {
  transform: scale(0.985);
}

/* ===== Day Header ===== */
.day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, var(--primary-light) 0%, #ffffff 100%);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.day-label {
  display: flex;
  align-items: center;
}

.day-emoji {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.day-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary-dark);
}

.day-date {
  font-size: 24rpx;
  color: var(--text-hint);
  background: rgba(255,255,255,0.7);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ===== Meal Section ===== */
.meals-wrap {
  padding: 20rpx 28rpx 24rpx;
}

.meal-section {
  margin-bottom: 20rpx;
  padding: 8rpx 8rpx 8rpx 20rpx;
  border-left: 8rpx solid var(--primary);
  background: linear-gradient(90deg, var(--primary-light) 0%, transparent 40%);
  border-radius: 4rpx;
}

.meal-section:last-child {
  margin-bottom: 0;
}

.meal-section.meal-snack {
  border-left-color: var(--orange);
  background: linear-gradient(90deg, var(--orange-light) 0%, transparent 40%);
}

.meal-label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.meal-emoji {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.meal-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

/* ===== Dish Tags ===== */
.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.dish-tag {
  padding: 10rpx 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.dish-tag:active {
  transform: translateY(2rpx);
}

.dish-color-0 {
  background: linear-gradient(135deg, #ffffff, #e6f7ff);
  color: #096dd9;
  border: 1px solid #bae7ff;
}

.dish-color-1 {
  background: linear-gradient(135deg, #ffffff, #f6ffed);
  color: #389e0d;
  border: 1px solid #d9f7be;
}

.dish-color-2 {
  background: linear-gradient(135deg, #ffffff, #fff7e6);
  color: #d46b08;
  border: 1px solid #ffd591;
}

.dish-color-3 {
  background: linear-gradient(135deg, #ffffff, #fff1f0);
  color: #cf1322;
  border: 1px solid #ffccc7;
}

/* ===== Empty ===== */
.day-empty {
  padding: 32rpx 28rpx;
  text-align: center;
}

.day-empty-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ===== Compact Mode ===== */
.compact .day-card {
  margin-bottom: 16rpx;
}

.compact .day-header {
  padding: 16rpx 24rpx;
}

.compact .meals-wrap {
  padding: 12rpx 24rpx 16rpx;
}

.compact .dish-tag {
  font-size: 24rpx;
  padding: 4rpx 14rpx;
}
