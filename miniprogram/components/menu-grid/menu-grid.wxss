.menu-grid {
  padding: 0;
}

/* ===== Day Card ===== */
.day-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 24rpx;
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
}

.day-card:active {
  transform: scale(0.985);
}

/* ===== Day Header ===== */
.day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, var(--primary-light), #e8fce0);
  border-bottom: 2rpx solid var(--border);
}

.day-label {
  display: flex;
  align-items: center;
}

.day-emoji {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.day-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary-dark);
}

.day-date {
  font-size: 24rpx;
  color: var(--text-hint);
  background: rgba(255,255,255,0.7);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ===== Meal Section ===== */
.meals-wrap {
  padding: 20rpx 28rpx 24rpx;
}

.meal-section {
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid var(--primary);
}

.meal-section:last-child {
  margin-bottom: 0;
}

.meal-section.meal-snack {
  border-left-color: var(--orange);
}

.meal-label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.meal-emoji {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.meal-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

/* ===== Dish Tags ===== */
.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.dish-tag {
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: transform 0.15s;
}

.dish-tag:active {
  transform: scale(0.95);
}

.dish-color-0 {
  background: linear-gradient(135deg, #e6f7ff, #bae7ff);
  color: #096dd9;
}

.dish-color-1 {
  background: linear-gradient(135deg, #f6ffed, #d9f7be);
  color: #389e0d;
}

.dish-color-2 {
  background: linear-gradient(135deg, #fff7e6, #ffd591);
  color: #d46b08;
}

.dish-color-3 {
  background: linear-gradient(135deg, #fff1f0, #ffccc7);
  color: #cf1322;
}

/* ===== Empty ===== */
.day-empty {
  padding: 32rpx 28rpx;
  text-align: center;
}

.day-empty-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ===== Compact Mode ===== */
.compact .day-card {
  margin-bottom: 16rpx;
}

.compact .day-header {
  padding: 16rpx 24rpx;
}

.compact .meals-wrap {
  padding: 12rpx 24rpx 16rpx;
}

.compact .dish-tag {
  font-size: 24rpx;
  padding: 4rpx 14rpx;
}
