.page-about {
  min-height: 100vh;
  background: var(--bg);
}

/* ===== Hero ===== */
.about-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.about-logo {
  font-size: 100rpx;
  margin-bottom: 16rpx;
  animation: floatEmoji 3s ease-in-out infinite;
}

@keyframes floatEmoji {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.about-name {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--primary-dark);
  margin-bottom: 8rpx;
}

.about-subtitle {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 12rpx;
}

.about-version {
  font-size: 22rpx;
  color: var(--text-hint);
  background: var(--card-bg);
  padding: 4rpx 20rpx;
  border-radius: 16rpx;
}

/* ===== Notices ===== */
.notice-section {
  background: #fff;
  border-radius: var(--radius);
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.notice-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.notice-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.notice-bell-icon {
  font-size: 32rpx;
}

.notice-header-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a3a2a;
}

.notice-unread-badge {
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  background: #ff4d4f;
  border-radius: 16rpx;
  padding: 0 8rpx;
}

.notice-arrow {
  font-size: 32rpx;
  color: #bfbfbf;
  transition: transform 0.2s;
  font-weight: 300;
}

.notice-arrow.expanded {
  transform: rotate(90deg);
}

.notice-list {
  border-top: 2rpx solid #f5f5f5;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  border-bottom: 2rpx solid #fafafa;
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-item.read {
  opacity: 0.4;
}

.notice-item-body {
  flex: 1;
  min-width: 0;
}

.notice-item-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1a3a2a;
  margin-bottom: 4rpx;
}

.notice-item-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.notice-mark-read {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #bfbfbf;
  margin-top: 4rpx;
}

/* ===== Cards ===== */
.about-card {
  margin-bottom: 24rpx;
}

.about-section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 20rpx;
}

.about-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* ===== Features ===== */
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.feature-icon {
  font-size: 44rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.feature-info {
  display: flex;
  flex-direction: column;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ===== Service Card ===== */
.service-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border: 2rpx solid #f0f0f0;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.service-card:active {
  transform: scale(0.98);
  border-color: #52c41a;
}

.service-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0fff0, #e6ffe6);
  border-radius: 20rpx;
  font-size: 36rpx;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
}

.service-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a3a2a;
}

.service-desc {
  font-size: 22rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

.service-arrow {
  font-size: 36rpx;
  color: #bfbfbf;
  font-weight: 300;
}

/* ===== Stats ===== */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--primary);
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: var(--border);
}

/* ===== Footer ===== */
.about-footer {
  padding: 48rpx 0 32rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #d9d9d9;
}
