.page-about {
  min-height: 100vh;
  background: var(--bg);
}

/* ===== Hero ===== */
.about-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.about-logo {
  font-size: 100rpx;
  margin-bottom: 16rpx;
  animation: floatEmoji 3s ease-in-out infinite;
}

@keyframes floatEmoji {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.about-name {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--primary-dark);
  margin-bottom: 8rpx;
}

.about-subtitle {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 12rpx;
}

.about-version {
  font-size: 22rpx;
  color: var(--text-hint);
  background: var(--card-bg);
  padding: 4rpx 20rpx;
  border-radius: 16rpx;
}

/* ===== Notice Bar ===== */
.notice-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #fffbe6, #fff7e0);
  border: 2rpx solid #ffe58f;
  border-radius: var(--radius);
}

.notice-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.notice-body {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8c6e00;
}

.notice-title {
  font-weight: 700;
  color: #ad6800;
  margin-right: 12rpx;
}

.notice-dots {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.notice-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #ffe58f;
  transition: all 0.3s;
}

.notice-dot.active {
  background: #faad14;
  width: 24rpx;
  border-radius: 5rpx;
}

/* ===== Cards ===== */
.about-card {
  margin-bottom: 24rpx;
}

.about-section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 20rpx;
}

.about-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* ===== Features ===== */
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.feature-icon {
  font-size: 44rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.feature-info {
  display: flex;
  flex-direction: column;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ===== Stats ===== */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--primary);
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: var(--border);
}

/* ===== Footer ===== */
.about-footer {
  padding: 48rpx 0 32rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #d9d9d9;
}
