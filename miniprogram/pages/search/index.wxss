.page-search {
  min-height: 100vh;
  background: var(--bg);
}

/* ===== Search Bar ===== */
.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: var(--radius);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.search-bar-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 64rpx;
  font-size: 28rpx;
  color: var(--text);
}

.search-clear {
  font-size: 28rpx;
  color: #bfbfbf;
  padding: 8rpx;
  font-weight: 700;
}

/* ===== Loading ===== */
.search-loading {
  text-align: center;
  padding: 60rpx 0;
  font-size: 26rpx;
  color: var(--text-hint);
}

/* ===== Results ===== */
.result-count {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
}

.result-item {
  margin-bottom: 16rpx;
  padding: 24rpx 28rpx;
}

.result-item:active {
  transform: scale(0.98);
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.result-week {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}

.result-date {
  font-size: 22rpx;
  color: var(--text-hint);
}

.result-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.result-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  background: var(--primary-light);
  color: var(--primary-dark);
  border-radius: 6rpx;
  font-weight: 600;
}

.result-dishes {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ===== Empty & Hint ===== */
.search-empty, .search-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-emoji, .hint-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text, .hint-text {
  font-size: 26rpx;
  color: var(--text-hint);
}
