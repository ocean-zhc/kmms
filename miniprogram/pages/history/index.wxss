.page-history {
  min-height: 100vh;
  background: var(--bg);
}

/* Hero */
.history-hero {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.hero-badge {
  display: inline-block;
  padding: 6rpx 24rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: 30rpx;
  font-weight: 700;
  font-size: 20rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 900;
  color: #1a3a2a;
}

.hero-sub {
  font-size: 26rpx;
  color: #8c8c8c;
  margin-top: 8rpx;
}

/* Month Navigator */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin: 20rpx 0 28rpx;
}

.month-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e8e8e8;
  border-radius: 50%;
  background: #fff;
}

.month-btn .arrow {
  font-size: 36rpx;
  color: #595959;
  font-weight: 300;
}

.month-btn.disabled {
  opacity: 0.3;
}

.month-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a3a2a;
  min-width: 200rpx;
  text-align: center;
}

/* Loading */
.month-loading {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  padding: 40rpx 0;
}

.loading-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--primary);
  animation: dotBounce 1.2s infinite;
}

.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

/* Timeline */
.timeline {
  position: relative;
  padding-left: 32rpx;
}

.timeline-line {
  position: absolute;
  left: 11rpx;
  top: 16rpx;
  bottom: 16rpx;
  width: 4rpx;
  background: #e8e8e8;
  border-radius: 2rpx;
}

.timeline-item {
  position: relative;
  margin-bottom: 20rpx;
  animation: fadeSlideIn 0.4s ease-out both;
}

.timeline-dot {
  position: absolute;
  left: -26rpx;
  top: 32rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--primary);
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 4rpx #e8e8e8;
}

.timeline-card {
  padding: 28rpx !important;
}

.timeline-card:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 24rpx rgba(82, 196, 26, 0.12);
}

.timeline-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* Calendar Icon */
.calendar-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(82, 196, 26, 0.15);
  display: flex;
  flex-direction: column;
  border: 1px solid #e8e8e8;
  flex-shrink: 0;
}

.calendar-month {
  background: var(--primary);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  text-align: center;
  padding: 4rpx 0;
  line-height: 1.3;
}

.calendar-day {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 800;
  color: #1a3a2a;
  background: #fff;
}

.timeline-info {
  flex: 1;
}

.timeline-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a3a2a;
  margin-bottom: 6rpx;
}

.timeline-date {
  font-size: 24rpx;
  color: #8c8c8c;
}

.timeline-arrow {
  font-size: 36rpx;
  color: #d9d9d9;
  font-weight: 300;
  flex-shrink: 0;
}

/* Empty Month */
.empty-month {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon-sm {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* Animations */
@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateX(-20rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}
