.page-history {
  min-height: 100vh;
  background: var(--bg);
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.history-title {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text);
}

.history-count {
  font-size: 24rpx;
  color: var(--text-hint);
  background: var(--card-bg);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* ===== Week Card ===== */
.week-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.week-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  transition: transform 0.2s;
  border: 2rpx solid rgba(82, 196, 26, 0.06);
}

.week-card:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 24rpx rgba(82, 196, 26, 0.12);
}

.week-card-left {
  margin-right: 24rpx;
}

.calendar-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.15);
  display: flex;
  flex-direction: column;
  border: 1px solid #e8e8e8;
}

.calendar-month {
  background: var(--primary);
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  text-align: center;
  padding: 4rpx 0;
  line-height: 1.3;
}

.calendar-day {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text);
  background: #fff;
}

.week-card-content {
  flex: 1;
}

.week-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
}

.week-card-date {
  font-size: 24rpx;
  color: var(--text-hint);
}

.week-card-arrow {
  font-size: 36rpx;
  color: var(--text-hint);
  font-weight: 300;
}

/* ===== Load More ===== */
.load-more {
  padding: 32rpx;
  text-align: center;
}

.load-more-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

.load-end {
  padding: 32rpx;
  text-align: center;
}

.load-end-text {
  font-size: 24rpx;
  color: #d9d9d9;
}
