.page-history {
  min-height: 100vh;
  background: var(--bg);
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.history-title {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text);
}

.history-count {
  font-size: 24rpx;
  color: var(--text-hint);
  background: var(--card-bg);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* ===== Week Card ===== */
.week-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.week-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  transition: transform 0.2s;
}

.week-card:active {
  transform: scale(0.98);
}

.week-card-left {
  margin-right: 24rpx;
}

.week-num-badge {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light), #d9f7be);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.week-num {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--primary-dark);
  line-height: 1;
}

.week-num-label {
  font-size: 18rpx;
  color: var(--primary);
  margin-top: 2rpx;
}

.week-card-content {
  flex: 1;
}

.week-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
}

.week-card-date {
  font-size: 24rpx;
  color: var(--text-hint);
}

.week-card-arrow {
  font-size: 36rpx;
  color: var(--text-hint);
  font-weight: 300;
}

/* ===== Load More ===== */
.load-more {
  padding: 32rpx;
  text-align: center;
}

.load-more-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

.load-end {
  padding: 32rpx;
  text-align: center;
}

.load-end-text {
  font-size: 24rpx;
  color: #d9d9d9;
}
