.page-index {
  min-height: 100vh;
  background: var(--bg);
}

/* ===== Hero Card ===== */
.hero-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.hero-card::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  filter: blur(40px);
  z-index: 1;
}

.hero-card::after {
  content: '';
  position: absolute;
  bottom: -50rpx;
  left: -50rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  filter: blur(30px);
  z-index: 1;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #2d8c1f 0%, #45a825 40%, #6abf4e 100%);
  opacity: 0.95;
}

.hero-content {
  position: relative;
  z-index: 2;
  padding: 40rpx 36rpx;
  color: #fff;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.hero-badge-text {
  font-weight: 500;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.3;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.hero-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #b7eb8f;
  box-shadow: 0 0 8rpx rgba(183,235,143,0.8);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.status-text {
  font-size: 24rpx;
  opacity: 0.9;
}

.hero-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.hero-decor {
  position: absolute;
  font-size: 56rpx;
  opacity: 0.15;
  z-index: 2;
  animation: floatDecor 4s ease-in-out infinite;
  pointer-events: none;
}

.decor-1 { top: 20rpx; right: 40rpx; }
.decor-2 { bottom: 20rpx; left: 30rpx; animation-delay: -1.5s; }
.decor-3 { top: 50%; right: 20%; animation-delay: -3s; font-size: 44rpx; }

@keyframes floatDecor {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

/* ===== Section ===== */
.section {
  margin-bottom: 8rpx;
}
