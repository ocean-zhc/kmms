.page-index {
  min-height: 100vh;
  background: var(--bg);
}

/* ===== Hero Card ===== */
.hero-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.hero-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: var(--primary-light);
  opacity: 0.5;
  z-index: 1;
}

.hero-card::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 193, 7, 0.06);
  z-index: 1;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary-bg) 40%, var(--bg) 100%);
}

.hero-content {
  position: relative;
  z-index: 2;
  padding: 40rpx 36rpx;
  color: var(--text);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: #fff;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
  border: 1px solid var(--primary-bg);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.hero-badge-text {
  font-weight: 600;
  color: var(--primary-dark);
}

.hero-title {
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.3;
  margin-bottom: 12rpx;
  color: #1a3a2a;
}

.hero-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--primary);
  box-shadow: 0 0 12rpx rgba(82, 196, 26, 0.5);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.status-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

.hero-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.hero-decor {
  position: absolute;
  font-size: 56rpx;
  opacity: 0.35;
  z-index: 2;
  animation: floatDecor 4s ease-in-out infinite;
  pointer-events: none;
}

.decor-1 { top: 20rpx; right: 40rpx; }
.decor-2 { bottom: 20rpx; left: 30rpx; animation-delay: -1.5s; }
.decor-3 { top: 50%; right: 20%; animation-delay: -3s; font-size: 44rpx; }

@keyframes floatDecor {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

/* ===== Notice Bar ===== */
.notice-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #fffbe6, #fff7e0);
  border: 2rpx solid #ffe58f;
  border-radius: var(--radius);
}

.notice-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.notice-body {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8c6e00;
}

.notice-title {
  font-weight: 700;
  color: #ad6800;
  margin-right: 12rpx;
}

.notice-dots {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.notice-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #ffe58f;
  transition: all 0.3s;
}

.notice-dot.active {
  background: #faad14;
  width: 24rpx;
  border-radius: 5rpx;
}

/* ===== Section ===== */
.section {
  margin-bottom: 8rpx;
}
