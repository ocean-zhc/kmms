.page-index {
  min-height: 100vh;
  background: var(--bg);
}

/* ===== Hero Card ===== */
.hero-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #52c41a, #73d13d, #95de64);
  opacity: 0.95;
}

.hero-content {
  position: relative;
  padding: 40rpx 36rpx;
  color: #fff;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(10px);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.hero-badge-text {
  font-weight: 500;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.3;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.hero-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #b7eb8f;
  box-shadow: 0 0 8rpx rgba(183,235,143,0.8);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.status-text {
  font-size: 24rpx;
  opacity: 0.9;
}

/* ===== Section ===== */
.section {
  margin-bottom: 8rpx;
}
