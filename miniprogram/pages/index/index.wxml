<view class="page-index">
  <!-- Loading -->
  <view class="container" wx:if="{{loading}}">
    <view class="skeleton skeleton-card"></view>
    <view class="skeleton skeleton-card" style="height: 300rpx;"></view>
    <view class="skeleton skeleton-card" style="height: 160rpx;"></view>
  </view>

  <!-- Empty -->
  <view class="empty-state" wx:elif="{{!hasData}}">
    <text class="empty-emoji">📋</text>
    <text class="empty-title">本周食谱尚未发布</text>
    <text class="empty-desc">园所正在精心准备中，请稍后查看</text>
  </view>

  <!-- Content -->
  <view class="container fade-in" wx:else>
    <!-- Hero Card -->
    <view class="hero-card card">
      <view class="hero-bg"></view>
      <view class="hero-content">
        <view class="hero-badge">
          <text>🍱</text>
          <text class="hero-badge-text">本周食谱</text>
        </view>
        <view class="hero-title">{{weekTitle}}</view>
        <view class="hero-status">
          <view class="status-dot"></view>
          <text class="status-text">已发布</text>
        </view>
      </view>
    </view>

    <!-- Menu Grid -->
    <view class="section">
      <view class="section-title">
        <text class="emoji">🍽</text>
        <text>每日食谱</text>
      </view>
      <menu-grid items="{{weekData.items}}" start-date="{{weekData.week_start}}" />
    </view>

    <!-- Nutrition -->
    <view class="section">
      <nutrition-chart week-id="{{weekId}}" />
    </view>

    <!-- AI Summary -->
    <view class="section">
      <ai-summary week-id="{{weekId}}" />
    </view>
  </view>
</view>
