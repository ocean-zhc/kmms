<view class="page-learning" style="{{themeStyle}}">
  <view class="container">
    <!-- Hero -->
    <view class="learning-hero">
      <view class="hero-badge">Daily Learning</view>
      <view class="hero-title">今日所学</view>
      <view class="hero-sub">记录宝贝每天的成长足迹</view>
    </view>

    <!-- Loading -->
    <view class="skeleton-card card" wx:if="{{loading}}">
      <view class="skeleton-line skeleton-w60"></view>
      <view class="skeleton-line skeleton-w80"></view>
      <view class="skeleton-line skeleton-w40"></view>
    </view>

    <!-- Today Card -->
    <view class="today-card card" wx:elif="{{today}}">
      <view class="today-tag">TODAY</view>
      <view class="today-header">
        <view class="subject-badge" style="background: {{today.color}}">{{today.icon}}</view>
        <view class="today-info">
          <view class="today-name">{{today.activity_name}}</view>
          <view class="today-date">{{today.dateText}}</view>
        </view>
      </view>
      <view class="today-goals">
        <view class="goal-item" wx:for="{{today.goals}}" wx:key="index" style="animation-delay: {{index * 0.1}}s">
          <view class="goal-num" style="background: {{today.color}}">{{index + 1}}</view>
          <view class="goal-text">{{item}}</view>
        </view>
      </view>
    </view>

    <!-- Empty Today -->
    <view class="empty-state" wx:elif="{{!loading && !today}}">
      <view class="empty-icon">📖</view>
      <view class="empty-title">今天还没有发布所学内容</view>
      <view class="empty-desc">老师发布后会自动更新</view>
    </view>

    <!-- Month Navigator -->
    <view class="month-nav">
      <view class="month-btn" bindtap="prevMonth" aria-label="上一月">
        <text class="arrow">‹</text>
      </view>
      <view class="month-label">{{monthLabel}}</view>
      <view class="month-btn {{isCurrentMonth ? 'disabled' : ''}}" bindtap="nextMonth" aria-label="下一月">
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- Month Loading -->
    <view class="month-loading" wx:if="{{monthLoading}}">
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
    </view>

    <!-- History Timeline -->
    <view class="timeline" wx:elif="{{monthData.length > 0}}">
      <view class="timeline-line"></view>
      <view class="timeline-item" wx:for="{{monthData}}" wx:key="id" style="animation-delay: {{index * 0.06}}s">
        <view class="timeline-dot" style="background: {{item.color}}"></view>
        <view class="timeline-card card">
          <view class="timeline-header">
            <text class="timeline-icon">{{item.icon}}</text>
            <text class="timeline-name">{{item.activity_name}}</text>
            <text class="timeline-date">{{item.dateText}}</text>
          </view>
          <view class="timeline-goals">
            <view class="timeline-goal" wx:for="{{item.goals}}" wx:for-item="goal" wx:for-index="gi" wx:key="gi">
              {{gi + 1}}. {{goal}}
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- Empty Month -->
    <view class="empty-month" wx:elif="{{!monthLoading && monthData.length === 0}}">
      <view class="empty-icon-sm">📄</view>
      <text class="empty-text">本月暂无记录</text>
    </view>
  </view>
</view>
