/* ===== CSS Variables (page scope) ===== */
page {
  --primary: #52c41a;
  --primary-dark: #389e0d;
  --primary-light: #f6ffed;
  --primary-bg: #e8f8e0;
  --blue: #1890ff;
  --blue-light: #e6f7ff;
  --orange: #fa8c16;
  --orange-light: #fff7e6;
  --red: #ff4d4f;
  --red-light: #fff1f0;
  --purple: #722ed1;
  --purple-light: #f9f0ff;
  --cyan: #13c2c2;
  --cyan-light: #e6fffb;
  --pink: #eb2f96;
  --pink-light: #fff0f6;
  --text: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --bg: #f8faf9;
  --card-bg: #ffffff;
  --border: #f0f0f0;
  --shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
  --shadow-sm: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  --radius: 28rpx;
  --radius-sm: 14rpx;
  --radius-lg: 36rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--text);
  background: var(--bg);
  line-height: 1.6;
}

/* ===== Utility ===== */
.container {
  padding: 24rpx 32rpx;
  padding-bottom: 40rpx;
}

.card {
  background: var(--card-bg);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.card-body {
  padding: 32rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text);
  margin: 16rpx 0 28rpx;
  display: flex;
  align-items: center;
  padding-left: 24rpx;
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  width: 8rpx;
  height: 34rpx;
  background: linear-gradient(180deg, var(--primary), var(--primary-bg));
  border-radius: 4rpx;
}

.section-title .emoji {
  margin-right: 12rpx;
  font-size: 38rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-green {
  background: var(--primary-light);
  color: var(--primary);
}

.tag-blue {
  background: var(--blue-light);
  color: var(--blue);
}

.tag-orange {
  background: var(--orange-light);
  color: var(--orange);
}

/* ===== Cache Pill ===== */
.cache-pill {
  display: inline-block;
  background: var(--primary-light);
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ===== Skeleton Loading ===== */
.skeleton {
  background: linear-gradient(110deg, #f0f0f0 30%, #f8f8f8 50%, #f0f0f0 70%);
  background-size: 200% 100%;
  animation: shimmer 1.2s ease-in-out infinite;
  border-radius: var(--radius-sm);
}

.skeleton-title {
  width: 60%;
  height: 40rpx;
  margin-bottom: 20rpx;
}

.skeleton-text {
  width: 100%;
  height: 28rpx;
  margin-bottom: 16rpx;
}

.skeleton-text-short {
  width: 40%;
  height: 28rpx;
}

.skeleton-card {
  height: 200rpx;
  margin-bottom: 24rpx;
  border-radius: var(--radius);
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== Glass ===== */
.glass {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
}

/* ===== Fade In ===== */
.fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== Loading Dots ===== */
.loading-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-dots .dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--primary);
  margin: 0 8rpx;
  animation: dotBounce 1.2s ease-in-out infinite;
}

.loading-dots .dot:nth-child(2) { animation-delay: 0.15s; }
.loading-dots .dot:nth-child(3) { animation-delay: 0.3s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* ===== Pull Refresh ===== */
.refresh-tip {
  text-align: center;
  color: var(--text-hint);
  font-size: 24rpx;
  padding: 16rpx;
}
